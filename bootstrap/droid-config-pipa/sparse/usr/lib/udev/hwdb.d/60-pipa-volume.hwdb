# Xiaomi Pad 6 (pipa) volume rockers — ensure KEY_VOLUMEUP / KEY_VOLUMEDOWN
# are exposed with the volume* key names Sailfish/MCE expect.
evdev:name:gpio-keys*
 KEYBOARD_KEY_73=volumeup
evdev:name:pm8941_resin*
 KEYBOARD_KEY_72=volumedown
evdev:name:*pon*pwrkey*
 KEYBOARD_KEY_72=volumedown
evdev:name:*pon_resin*
 KEYBOARD_KEY_72=volumedown
