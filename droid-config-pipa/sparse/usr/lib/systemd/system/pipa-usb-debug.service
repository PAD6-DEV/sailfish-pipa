[Unit]
Description=Enable Sailfish pipa USB debugging (sshd config/accounts)
DefaultDependencies=no
After=local-fs.target
# Do not order Before=sshd or multi-user — that deadlocks if we touch sshd.

[Service]
Type=oneshot
ExecStart=/usr/libexec/pipa-usb-debug-enable.sh
RemainAfterExit=yes
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
